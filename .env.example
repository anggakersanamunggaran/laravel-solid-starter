APP_NAME=LaravelBoilerPlate
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# ---------------------------------------------------------------------------
# Database — MySQL 8
# Matches the service name defined in docker-compose.yml
# ---------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=laravel_boilerplate
DB_USERNAME=laravel
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret

# ---------------------------------------------------------------------------
# Cache / Session / Queue
# Use 'database' or 'redis' for production; 'sync' for local debugging
# ---------------------------------------------------------------------------
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

QUEUE_CONNECTION=database

# ---------------------------------------------------------------------------
# Mail — configured for Mailpit (local Docker dev tool)
# ---------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# Broadcast
# ---------------------------------------------------------------------------
BROADCAST_CONNECTION=log

# ---------------------------------------------------------------------------
# Filesystem
# ---------------------------------------------------------------------------
FILESYSTEM_DISK=local

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Sanctum
# ---------------------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8080,127.0.0.1,127.0.0.1:8080
